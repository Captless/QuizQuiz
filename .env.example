# ─── Supabase ────────────────────────────────────────────
# Generate these from your Supabase project dashboard.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Service Role (server-side only) ───────────
# Keep this secret. Found in Supabase > Settings > API.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Enabled ──────────────────────────────────
# Set to true when a functional Supabase project is configured.
# When false, usage/profile endpoints return 503 “offline” responses.
# Must be true in production (the server will abort if it's not).
SUPABASE_ENABLED=true

# ─── Local Fallback (dev only) ─────────────────────────
# When true, profile/usage data is stored in data/usage.json
# instead of the Supabase profiles table. Requires SUPABASE_ENABLED=true
# for authentication to work.
USE_LOCAL_FALLBACK=false

# ─── Site URL (OAuth redirect) ──────────────────────────
# The origin where the app is hosted (e.g. https://my-app.onrender.com).
# Used as the OAuth redirect target after Google sign‑in.
# Falls back to window.location.origin if omitted.
VITE_SITE_URL=http://localhost:5173

# ─── AI Provider (pick at least one) ────────────────────
# OpenRouter gives you access to many models. Get a key at https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-v1-...
# Optional: specify a model, otherwise fallbacks are used
OPENROUTER_MODEL=qwen/qwen3-coder:free

# Groq provides a free tier. Get a key at https://console.groq.com/keys
GROQ_KEY=gsk_...

# ─── Stripe (payments) ──────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get this from Stripe > Webhooks > Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: direct payment link (e.g., for price IDs)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/...

# ─── Google OAuth (authentication) ──────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=1234567890-xxxxx.apps.googleusercontent.com

# ─── CORS ──────────────────────────────────────────────
# Frontend origin for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173,https://your-app.onrender.com

# ─── Rate Limiting ─────────────────────────────────────
# Max requests per minute on generation endpoints
UPSTREAM_RATE_LIMIT=20

# ─── Server ────────────────────────────────────────────
PORT=3000
